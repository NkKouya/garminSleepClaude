# ===== 必須: Garmin Connect のログイン情報 =====
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# garth トークンキャッシュの保存先（省略可）
TOKEN_STORE=./.garminconnect

# ===== 分析バックエンド（LLMエンジン）の選択 =====
#   Claude のサブスク/課金が無くても、無料の ollama / gemini で同じ分析が動く。
#   claude_cli : Claude Code CLI（サブスク・無料）。既定。
#   ollama     : ローカルLLM（無料・データがPCの外に出ない）。無料の本命・推奨。
#   gemini     : Google Gemini の無料枠（手軽だが、無料枠が account/地域で使えないことあり）
#   claude_api : Claude API（従量課金）
BACKEND=claude_cli

# --- ollama を使う場合（BACKEND=ollama）★無料の推奨 ---
# 別途 Ollama を起動し、モデルを pull しておくこと（例: ollama pull qwen2.5:7b）
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# --- gemini を使う場合（BACKEND=gemini）---
# 無料APIキー: https://aistudio.google.com で発行
# 注意: 429 / "limit: 0" が出たら無料枠が未付与。GEMINI_MODEL=gemini-2.5-flash を試すか、
#       BACKEND=ollama に切り替える（待っても回復しない）。
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ===== Gmail送信設定（メール送信モードで必要）=====
#   無料・詳細モード(detailed_report.py) と 有料・自動モード(main.py) のメール送信で必要。
#   detailed_report.py を --no-mail で実行する場合は不要。
#   GMAIL_APP_PASSWORD は通常のログインパスワードではなく「アプリパスワード」を入れること
#   Googleアカウント → セキュリティ → 2段階認証 → アプリパスワード で発行（16文字）
GMAIL_ADDRESS=mckouya@gmail.com
GMAIL_APP_PASSWORD=
# レポートの送信先（省略時は GMAIL_ADDRESS 宛）
MAIL_TO=

# ===== 任意: 有料・自動モード(main.py) でのみ必要 =====
# Anthropic (Claude) API キー  https://console.anthropic.com で発行（従量課金）
# 無料モードでは不要。
ANTHROPIC_API_KEY=
